# Append these to Oikos's .env (e.g. /docker/oikos/.env), then `docker compose up -d`.

# Base URL of your Grocy server WITHOUT a trailing /api.
# If Oikos and Grocy are on different Docker networks, use the host IP + published port.
GROCY_URL=http://192.168.1.10:9283

# A Grocy API key (Grocy → user menu → Manage API keys). Use a dedicated key for Oikos.
GROCY_API_KEY=replace-with-your-grocy-api-key

# Optional: per-request timeout to Grocy in milliseconds (default 8000).
# GROCY_TIMEOUT_MS=8000
